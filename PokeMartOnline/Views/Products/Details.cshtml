@model PokeMartOnline.Models.Product


<div class="container mt-5">
    <div class="row">

        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded shadow" />
        </div>

        <div class="col-md-6">
            <h2>@Model.Name</h2>

            <span class="badge bg-success">NEW</span>

            <h3 class="text-primary mt-3">$@Model.Price</h3>

            <p class="mt-3">@Model.Description</p>

            <p class="text-success fw-bold">
                @Model.StockQuantity in stock
            </p>

            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                <input type="hidden" name="productId" value="@Model.Id" />

                <div class="mb-3">
                    <label>Quantity</label>
                    <input type="number" name="quantity" value="1" min="1"
                           class="form-control w-25" />
                </div>

                <button class="btn btn-danger">
                    Add to Cart
                </button>

                @if (TempData["Error"] != null)
                {
                    <div class="text-danger mt-2 fw-bold">
                        @TempData["Error"]
                    </div>
                }
            </form>
        </div>

    </div>
</div>