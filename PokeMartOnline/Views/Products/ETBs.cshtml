@model IEnumerable<PokeMartOnline.Models.Product>

<div class="container mt-4">
    <h2 class="mb-4">Elite Trainer Boxes</h2>

    @if (Context.Session.GetString("Role") == "Admin")
    {
        <a asp-controller="AdminProducts" asp-action="Create"
           class="btn btn-success mb-3">
            Add Product (Admin)
        </a>
    }

    <div class="row">
        @foreach (var product in Model)
        {
            <div class="col-md-4 col-lg-3 mb-4">
                <div class="card h-100 shadow-sm">

                    <img src="@product.ImageUrl" class="card-img-top" style="height:250px; object-fit:cover;" />

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@product.Name</h5>

                        <p class="text-primary fw-bold">$@product.Price</p>

                        <p class="text-muted small">
                            @(product.Description?.Length > 60
                                ? product.Description.Substring(0, 60) + "..."
                                : product.Description)
                        </p>

                        <div class="mt-auto">
                            <a asp-action="Details" asp-route-id="@product.Id"
                               class="btn btn-outline-primary w-100 mb-2">
                                View Details
                            </a>
                            @if (Context.Session.GetString("Role") == "Admin")
                            {
                                <a asp-controller="AdminProducts"
                                   asp-action="Edit"
                                   asp-route-id="@product.Id"
                                   class="btn btn-warning w-100 mb-2">
                                    Edit Product
                                </a>
                            }

                            <form asp-controller="Cart" asp-action="AddToCart" method="post">
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button class="btn btn-danger w-100">
                                    Add to Cart
                                </button>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>
</div>