@model List<PokeMartOnline.Models.LeaderboardModel>

<div class="container mt-4">

    <h1 class="mb-4">
        🏆 Customer Leaderboard
    </h1>

    <table class="table table-striped table-bordered">

        <thead class="table-dark">
            <tr>
                <th>Rank</th>
                <th>Customer</th>
                <th>Total Orders</th>
                <th>Items Purchased</th>
                <th>Total Spent</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var user in Model)
            {
                <tr>

                    <td>
                        @if (user.Rank == 1)

                        {
                            <span>🥇 #1</span>
                        }

                        else if (user.Rank == 2)

                        {
                            <span>🥈 #2</span>
                        }

                        else if (user.Rank == 3)

                        {
                            <span>🥉 #3</span>
                        }

                        else

                        {
                            <span>#@user.Rank</span>
                        }
                    </td>

                    <td>@user.CustomerName</td>

                    <td>@user.TotalOrders</td>

                    <td>@user.TotalItemsPurchased</td>

                    <td>$@user.TotalSpent</td>

                </tr>
            }

        </tbody>

    </table>

</div>