@model DataAccessLayer.Entities.Product

<h2>Edit Product</h2>

<form asp-action="Edit" method="post">

    <input type="hidden" asp-for="product_id" />

    <input asp-for="ProductName" class="form-control" />
    <br />

    <textarea asp-for="description" class="form-control"></textarea>
    <br />

    <input asp-for="price" class="form-control" />
    <br />

    <input asp-for="QuantityAvailable" class="form-control" />
    <br />

    <input asp-for="ImageUrl" class="form-control" />
    <br />

    <input asp-for="condition" class="form-control" />
    <br />

    <input asp-for="grade" class="form-control" />
    <br />

    <button class="btn btn-primary">
        Save Changes
    </button>

</form>