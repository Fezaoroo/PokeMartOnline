<h2>Login</h2>

<form asp-action="Login" method="post">
    <div>
        <label>Email</label>
        <input type="text" name="email" />
    </div>

    <div>
        <label>Password</label>
        <input type="password" name="password" />
    </div>

    <button type="submit">Login</button>
</form>

@if (ViewBag.Error != null)
{
    <p style="color:red">@ViewBag.Error</p>
}